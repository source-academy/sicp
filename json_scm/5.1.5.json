[{"id":"/sicp/5.1.5","tag":"TITLE","body":"5.1.5  \n    Instruction Summary"},{"tag":"TEXT","id":"#p1","child":[{"body":"\n    A controller instruction in our register-machine language\n    has one of the following forms, where each\n    ","tag":"#text"},{"tag":"META","body":"input"},{"body":"$_i$","tag":"LATEX"},{"body":" is\n    \n\teither\n      ","tag":"#text"},{"tag":"SCHEMEINLINE","body":"(reg register-name)"},{"body":"\n    or\n    ","tag":"#text"},{"tag":"SCHEMEINLINE","body":"(const constant-value)"},{"body":".","tag":"#text"}]},{"tag":"TEXT","id":"#p2","child":[{"body":"\n    These instructions were introduced in\n    section ","tag":"#text"},{"tag":"REF","body":"5.1.1","href":"/sicp/5.1.1"},{"body":":\n    ","tag":"#text"},{"tag":"SNIPPET","latex":true,"eval":false,"body":"\n(assign $register-name$ (reg $register-name$))\n\n(assign $register-name$ (const $constant-value$))\n\n(assign $register-name$ (op $operation-name$) $input_{1}$ $\\ldots$ $input_{n}$)\n\n(perform (op $operation-name$) $input_{1}$ $\\ldots$ $input_{n}$)\n\n(test (op $operation-name$) $input_{1}$ $\\ldots$ $input_{n}$)\n\n(branch (label $label-name$))\n\n(goto (label $label-name$))\n      "}]},{"tag":"TEXT","id":"#p3","child":[{"body":"\n    The use of registers to hold labels was introduced in\n    section ","tag":"#text"},{"tag":"REF","body":"5.1.3","href":"/sicp/5.1.3"},{"body":":\n    ","tag":"#text"},{"tag":"SNIPPET","latex":true,"eval":false,"body":"\n(assign $register-name$ (label $label-name$))\n\n(goto (reg $register-name$))\n      "}]},{"tag":"TEXT","id":"#p4","child":[{"body":"\n    Instructions to use the stack were introduced in\n    section ","tag":"#text"},{"tag":"REF","body":"5.1.4","href":"/sicp/5.1.4"},{"body":":\n    ","tag":"#text"},{"tag":"SNIPPET","latex":true,"eval":false,"body":"\n(save $register-name$)\n\n(restore $register-name$)\n      "}]},{"tag":"TEXT","id":"#p5","child":[{"body":"\n    The only kind of\n    ","tag":"#text"},{"body":"$\\langle constant-value \\rangle$","tag":"LATEX"},{"body":"\n    we have seen so far is a number, but later we will \n    use strings, symbols,\n    and lists.\n    \n\tFor example,\n\t","tag":"#text"},{"tag":"SCHEMEINLINE","body":"(const \"abc\")"},{"body":" is the string\n\t","tag":"#text"},{"tag":"SCHEMEINLINE","body":"\"abc\""},{"body":",\n\t","tag":"#text"},{"tag":"SCHEMEINLINE","body":"(const abc)"},{"body":" is the symbol\n\t","tag":"#text"},{"tag":"SCHEMEINLINE","body":"abc"},{"body":",\n\t","tag":"#text"},{"tag":"SCHEMEINLINE","body":"(const (a b c))"},{"body":"\n\tis the list\n\t","tag":"#text"},{"tag":"SCHEMEINLINE","body":"(a b c)"},{"body":",\n\tand\n\t","tag":"#text"},{"tag":"SCHEMEINLINE","body":"(const ())"},{"body":"\n\tis the empty list.\n      ","tag":"#text"}]}]