% makeindex wraps its output at a default line length (around 72 chars),
% which is fine for plain text but can land in the middle of a generated
% \lstinline{...} macro call for a long inline-code index entry, breaking it
% ("Package Listings Error: lstinline ended by EOL" — lstinline's delimited
% argument can't span a line break). Raise the limit well above anything a
% real entry should ever reach, so index lines are never auto-wrapped.
line_max 4096
