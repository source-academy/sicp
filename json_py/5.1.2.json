")),\n    \"rem_done\",\n      assign(\"a\", reg(\"b\")),\n      assign(\"b\", reg(\"t\")),\n      go_to(label(\"test_b\")),\n    \"gcd_done\")) "},"captionHref":"/sicpy/5.1.2#fig-5.6","captionName":"Figure 5.6 ","captionBody":[{"body":"Controller instruction sequence for the GCD machine in\n      figure ","tag":"#text"},{"tag":"REF","body":"5.5","href":"/sicpy/5.1.2#fig-5.5"},{"body":".","tag":"#text"}]}]},{"tag":"EXERCISE","title":"Exercise 5.3","id":"#ex-5.3","child":[{"body":"\n    Design a machine to compute\n    \n    square roots using Newton's method, as\n    described in section ","tag":"#text"},{"tag":"REF","body":"1.1.7","href":"/sicpy/1.1.7"},{"body":" and implemented with the following code in section ","tag":"#text"},{"tag":"REF","body":"1.1.8","href":"/sicpy/1.1.8"},{"body":":\n    ","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":4,"eval":true,"prependLength":6,"program":"chap=4&prgrm=MQAgygkgwgCgniArAOgIzIEwCgsBMCmAZiAM4COArgIYBO+AFAB4CUAXCHQC4U0B2IjEACoBOAsSoA3fDSoBzBowA0IOGywhNHfNz4gmIANSrmIAPQhseIqTI1OTdVpDiQASxIB9OQHsfuT3xeHwo5AAt6OQp8EhInZy0uHn4AWypOMM8qACMSenJqOkjo2NMAWgFTAB4QAAZkWtrUDS1XNxSABxofaWKYuNYWhO1dfikZeQYo-pVBC2nSoZcbcntPN04ZPtLB4c0kvQWSd2IPbz8AoJDw7biQfAAbEnxbNY2t9q6eqZK45iWDvxVpx1psaPRUP8sF03LwHMD6IhmMwgA","body":"def sqrt(x):\n    def is_good_enough(guess):\n        return math_abs(square(guess) - x) < 0.001\n    def improve(guess):\n        return average(guess, x / guess)\n    def sqrt_iter(guess):\n        return guess if is_good_enough(guess) else sqrt_iter(improve(guess))\n    return sqrt_iter(1) "},{"body":"\n    Begin by assuming that\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"is_good_enough"},{"body":"\n    and ","tag":"#text"},{"tag":"PYTHONINLINE","body":"improve"},{"body":" operations are available as\n    primitives.  Then show how to expand these in terms of arithmetic\n    operations.  Describe each version of the ","tag":"#text"},{"tag":"PYTHONINLINE","body":"sqrt"},{"body":"\n    machine design by drawing a data-path diagram and writing a controller\n    definition in the register-machine language.\n    ","tag":"#text"}]}]