_name) if is_undefined(val)\n            else tail(val)) "}]},{"tag":"EXERCISE","title":"Exercise 5.8","id":"#ex-5.8","child":[{"body":"\n    The following register-machine code is ambiguous, because the label\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"here"},{"body":" is defined more than once:\n    ","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":7,"eval":false,"body":"\"start\",\n  go_to(label(\"here\")),\n\"here\",\n  assign(\"a\", constant(3)),\n  go_to(label(\"there\")),\n\"here\",\n  assign(\"a\", constant(4)),\n  go_to(label(\"there\")),\n\"there\","},{"body":"\n    With the simulator as written, what will the contents of register\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"a"},{"body":" be when control reaches\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"there"},{"body":"?  Modify the\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"extract_labels"},{"body":"function\n    so that the assembler will signal an error if the same label\n    name is used to indicate two different locations.\n    ","tag":"#text"}]},{"tag":"DISPLAYFOOTNOTE","id":"#footnote-1","count":1,"href":"/sicpy/5.2.2#footnote-link-1","child":[{"body":"\n    Using the\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"receive"},{"body":"function\n    here is a way to get\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"extract_labels"},{"body":"\n    to effectively return two\n    values—","tag":"#text"},{"tag":"PYTHONINLINE","body":"labels"},{"body":" and\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"insts"},{"body":"—without explicitly making a\n    compound data structure to hold them.  An alternative implementation, which\n    returns an explicit pair of values, is\n    ","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":8,"eval":false,"body":"def extract_labels(controller):\n    if is_null(controller):\n        return pair(None, None)\n    else:\n        result = extract_labels(tail(controller))\n        insts = head(result)\n        labels = tail(result)\n        next_element = head(controller)\n        return (pair(insts, pair(make_label_entry(next_element, insts), labels))\n                if is_string(next_element)\n                else pair(pair(make_inst(next_element), insts), labels))"},{"body":"\n    which would be called by ","tag":"#text"},{"tag":"PYTHONINLINE","body":"assemble"},{"body":" as follows:\n    ","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":9,"eval":false,"body":"def assemble(controller, machine):\n    result = extract_labels(controller)\n    insts = head(result)\n    labels = tail(result)\n    update_insts(insts, labels, machine)\n    return insts"},{"body":"\n\n    You can consider our use of ","tag":"#text"},{"tag":"PYTHONINLINE","body":"receive"},{"body":" as\n    demonstrating an elegant way to\n    \n    return multiple values, or simply an excuse\n    to show off a programming trick.  An argument like\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"receive"},{"body":" that is the next\n    function\n    to be invoked is called a\n    \"","tag":"#text"},{"body":"continuation.","tag":"#text"},{"body":"\"  Recall that we\n    also used continuations to implement the backtracking control\n    structure in the ","tag":"#text"},{"tag":"PYTHONINLINE","body":"amb"},{"body":" evaluator in\n    section ","tag":"#text"},{"tag":"REF","body":"4.3.3","href":"/sicpy/4.3.3"},{"body":".","tag":"#text"}]}]