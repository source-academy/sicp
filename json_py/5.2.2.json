 machine)\n        return insts\n    return extract_labels(controller, receive) "}]},{"tag":"TEXT","id":"#p4","child":[{"body":"\n\t      The function ","tag":"#text"},{"tag":"PYTHONINLINE","body":"extract_labels"},{"body":" takes\n\t      a list ","tag":"#text"},{"tag":"PYTHONINLINE","body":"controller"},{"body":" \n\t      and a function ","tag":"#text"},{"tag":"PYTHONINLINE","body":"receive"},{"body":"\n\t      as arguments. The function ","tag":"#text"},{"tag":"PYTHONINLINE","body":"receive"},{"body":" will\n\t      be called with two values: (1) a list ","tag":"#text"},{"tag":"PYTHONINLINE","body":"insts"},{"body":"\n\t      of instruction data structures, each containing an instruction from\n\t      ","tag":"#text"},{"tag":"PYTHONINLINE","body":"controller"},{"body":"; and (2) a table called\n\t      ","tag":"#text"},{"tag":"PYTHONINLINE","body":"labels"},{"body":", which associates each label from\n\t      ","tag":"#text"},{"tag":"PYTHONINLINE","body":"controller"},{"body":" with the position in the list\n\t      ","tag":"#text"},{"tag":"PYTHONINLINE","body":"insts"},{"body":" that the label designates.\n      ","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":2,"eval":true,"prependLength":385,"program":"chap=4&-JA8OlyLoqPRev48px4jxUgJLCJLFwJOO5MpFOptKZ4hZbKKOBKpAo01mRHE9QOVFwAA8pgQfjGxD5-I7hfy9pEVNaJLbvLsmexmDH43pxZTvFLc30SAXo1NSZpKrXXZTPrFaMtsCQFCBvBmQIws-i5bXi6WKdUpFLuRMpiKTPwpKmLbW+fxR82Ka3dO26J3uxO+wObek3B4OIW9KP9m6OFLUifMp5uEmAmJXI-zyvXOu+x8VW2hF3LsQHvSssnYKQ8g3D1r0pX5-mSIEQXBXRa3UK5BlKcpaUNS4aRRNExCbTlAyoKFXiaC9mHwYtE3iZMFTTdZNgo6Qxw2KcxhnYM5m4ciYSojZR2Yl4YSVFQSHwIFJ3OUhLx3Tt+27UieNDcNIxjaifjohIU3Nak5BEX83VafjBkElj7UgpsNy3PUO2Akg9D0ag4EoSQ7TwDhXMkEI9DgNhfCaPi9Do+TAMU-BuxowyLikti-XsaVxAcFg8gyM95QxBptG8cJYLaVVqGoTJkjwlKWDNd9MosQJrly8J-UIcrUpPeVuBalh3L6DhahhMc7PpHovRZTrupkXqBiaDkkrG+sNMvMbqkm-qCsGrphuZRktqWnq+sGdlEoDcgqDGuNqh0hilyFJ4WLEsQ9G8McmQ4VI72caqsi8ejX2S1r8lq3oZA5Q5jgbC8pTmsGFqBtgN3myh4qlZ8TsoMzKJXOMEdrS7fsVEToTeDcTPHY90a6kdsZjYmSapagaTiIMZjmMNxA