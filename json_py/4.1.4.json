HZXEw6qnVorOwI0BWRYcE7oJ7uQFIAAcjkvkQiaS5xSqYGHYjkVI8CtB7jV3ICWW6c---C6OQ552m9ZdkmU6T867ad+qQG0Fg+bkzAlq2slSNSPbKGKoNdSGcr1zBzb+p26uGAKoxy7bqua-ULQYQAKzwauG6I8SJvTpNSPqz27tb1STr4vCJLkxke+2vvO40xCNE3yvdp3teqOwkcNDiBIkhSHaXQP2VEIPtysmmXsguPnasLxORZtXz-EMsNIUgB5uy9hoF-GCvx-hJGBIeMBXgqC0Cfu3fuoEURP06mtOuDpGQIJ8Mg7eOgB7D1Ht1Fu2VloDVWlpFg6gRqY2GIUJYpA9wgLBLkcI25YitjRHQNhR5mgnkAQafhYDOGFG4YPZEojchAA","body":"the_global_environment = setup_environment() "}]},{"tag":"TEXT","id":"#p4","child":[{"body":"\n\tIt does not matter how we represent primitive function objects, so long\n\tas ","tag":"#text"},{"tag":"PYTHONINLINE","body":"apply"},{"body":" can identify and apply them using\n\tthe functions ","tag":"#text"},{"tag":"PYTHONINLINE","body":"is_primitive_function"},{"body":"\n\tand ","tag":"#text"},{"tag":"PYTHONINLINE","body":"apply_primitive_function"},{"body":".  We\n\thave chosen to represent a primitive function as a list beginning with\n\tthe string ","tag":"#text"},{"tag":"PYTHONINLINE","body":"\"primitive\""},{"body":" and\n\tcontaining a function in the underlying JavaScript that implements that\n\tprimitive.\n\t","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":3,"eval":true,"prependLength":4,"program":"chap=4&prgrm=MQAgygkgwgCgniALAOgIzMQKEwEwKYBmIAlgM4D6ALgIYDmteO5ANmZQBQDGA9gLYAO3AHZ4hlADQhKACzxU6ASgBcmEGpAAnPJQCuGoSQr9qxDVz6CRYhSGpCcIWdRzmBw0ZRsBeL1NnzabHwiMnJ+DWJeYkpiADc5Ah0hThjhdkShZVV1LV19QwCGJlZSDgzJACJwyOi4vAqFIMIQaqiY+PJI-mY8Xg9qVKF0pKz1TW09AycXGmJmYczGzF44MIi2urDmHVIQX2YSjir12viKyWZqXgAjHGoQAA9JOCUQdgeQAGoQOAVG6rE7FCrVOCSSKWIaRWaxq7Tk3R2f0wAI4ILhnQEPT6YgGkKG0LRmwRpD+QA","body":"def is_primitive_function(fun):\n    return is_tagged_list(fun, \"primitive\")\n\ndef primitive_implementation(fun):\n    return head(tail(fun)) "}]},{"tag":"TEXT","id":"#p5","child":[{"body":"The function\n      ","tag":"#text"},{"tag":"PYTHONINLINE","body":"setup_environment"},{"body":"\n    will get the primitive names and implementation \n    functions\n    from a list:","tag":"#text"},{"tag":"FOOTNOTE_REF","id":"#footnote-link-1","body":"1","href":"/sicpjs/4.1.4#footnote-1"},{"tag":"SNIPPET","latex":true,"eval":false,"body":"\nconst primitive_functions = llist(llist(\"head\",    head             ),\n                                 llist(\"tail\",    tail             ),\n                                 llist(\"pair\",    pair             ),\n                                 llist(\"is_null\", is_none          ),\n                                 llist(\"+\",       (x, y) => x + y  ),\n                                 $\\langle{}$more primitive functions$\\rangle$\n                                )\n\n\nconst primitive_function_symbols =\n    map(f => head(f), primitive_functions)\n\n\nconst primitive_function_objects =\n    map(f => llist(\"primitive\", head(tail(f))),\n        primitive_functions)\n      "}]},{"tag":"TEXT","id":"#p6","child":[{"body":"\n\tSimilar to primitive functions, we define other primitive constants that are\n\tinstalled in the global environment by the function\n\t","tag":"#text"},{"tag":"PYTHONINLINE","body":"setup_environment"},{"body":".\n\t","tag":"#text"},{"tag":"SNIPPET","latex":true,"eval":false,"body":"\nconst primitive_constants = llist(llist(\"undefined\", None),\n                                 llist(\"math_PI\",   math_pi)\n                                 $\\langle{}$more primitive constants$\\rangle$\n                                )\n\n\t\t\t\t \nconst primitive_constant_symbols =\n    map(c => head(c), primitive_constants)\n\n\nconst primitive_constant_values =\n    map(c => head(tail(c)), primitive_constants)\n\t  "}]},{"tag":"TEXT","id":"#p7","child":[{"body":"\n    To apply a \n    primitive function,\n    we simply apply the implementation\n    function\n    to the arguments, using the underlying\n    Python\n    system:","tag":"#text"},{"tag":"FOOTNOTE_REF","id":"#footnote-link-2","body":"2","href":"/sicpjs/4.1.4#footnote-2"},{"tag":"SNIPPET","latex":false,"id":4,"eval":true,"prependLength":14,"program":"chap=4&prgrm=MQAgygkgwgCgniALAOgIzMQKEwEwKYBmIAlgM4D6ALgIYDmteO5ANmZQBQDGA9gLYAO3AHZ4hlADQhKACzxU6ASgBcmEGpAAnPJQCuGoSQr9qxDVz6CRYhSGpCcIWdRzmBw0ZRsBeL1NnzabHwiMnJ+DWJeYkpiADc5Ah0hThjhdkShZVV1LV19QwCGJlZSDgzJACJwyOi4vAqFIMIQaqiY+PJI-mY8Xg9qVKF0pKz1TW09AycXGmJmYczGzF44MIi2urDmHVIQX2YSjir12viKyWZqXgAjHGoQAA9JOCUQdgeQAGoQOAVG6rE7FCrVOCSSKWIaRWaxq7Tk3R2f0wAI4ILhnQEPT6YgGkKG0LRmwRpCRuGa1H43VWhI6GQhaXKtg0tEOoxyE3yFKpnSE5CS+A0zDgxCEtHIACtqLFqKROBF+KiTuiulj+oMFgpJNRmazsFyhTCNrTweqCUqidtSBdDuxUJIAEx-IA","body":"def apply_primitive_function(fun, arglist):\n    return apply_in_underlying_javascript(primitive_implementation(fun), arglist) "}]},{"tag":"TEXT","id":"#p8","child":[{"body":"\n\tFor convenience in running the metacircular evaluator, we provide a\n\t","tag":"#text"},{"tag":"EM","child":[{"body":"driver loop","tag":"#text"}]},{"body":" that models the read-evaluate-print loop of \n\tthe underlying JavaScript system. It prints a \n\t","tag":"#text"},{"tag":"EM","child":[{"body":"prompt","tag":"#text"}]},{"body":" and reads an input program as a string.\n\tIt transforms the program string\n\tinto a tagged-list representation of the statement as described in\n\tsection ","tag":"#text"},{"tag":"REF","body":"4.1.2","href":"/sicpjs/4.1.2"},{"body":"—a\n\tprocess called parsing and accomplished by the primitive function\n\t","tag":"#text"},{"tag":"PYTHONINLINE","body":"parse"},{"body":".\n\tWe precede each printed result by\n\tan ","tag":"#text"},{"tag":"EM","child":[{"body":"output prompt","tag":"#text"}]},{"body":" so as to distinguish the value of the\n\tprogram from other output that may be printed. The driver loop gets\n\tthe program environment of the previous program as argument.\n\tAs described at the end of section ","tag":"#text"},{"tag":"REF","body":"3.2.4","href":"/sicpjs/3.2.4"},{"body":", the\n\tdriver loop treats the program as if it were in a block: It\n\tscans out the declarations, extends the given environment by a frame\n\tcontaining a binding of each name to\n\t","tag":"#text"},{"tag":"PYTHONINLINE","body":"\"*unassigned*\""},{"body":", and evaluates\n\tthe program with respect to the extended environment, which\n\tis then passed as argument to the next iteration of the driver loop.\n\t","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":5,"eval":true,"prependLength":311,"program":"chap=4&-Fk13VpaFXjUtm9bn--X04zF11ftFj44T+bkLIdPExdF04+Ivw2FlQLfaCVzqDQ86k9dIslo62yQiY1UfsJ84jNcxXcbjA5GmqtJmrOOga6ilmkAw+A8Hsb7stbD5hC6arzB+m7PGeTm6td+xsoH1A2xqhrwmOG5PsH8qYqiLMG6+kdZMatvIRVxICgpcHJ68XE8QOzZtuObSkMwpDq2ePa4Dy3PENwxb2rr-x1wbnsft3ehnvoA-iTh+QvohFMiLLSHLn2B4M7BGGNxPWv+oGX2RBHhwfvuquwu6SeC0L9XymXlsRAB23oU+jv5PdVV9yoSVofEzSRM6B8SkHmH5C-q4Jk6PdME0Ejzxg6BLH+IB7q--o7RExpOuhk481SYwkWHoA2QdTmmdGyjU4p3DInc2idIcWxc6nKn-jfVhJSghlI8aozJVS5nxACbjDZOhcGNBGVdFkUTlAxM5uMk5kzYlhOlokHiOyAQMP3kw9B1zFkmPOac05QcZYWyXLQtB39nGjKWXYRRKzKm3xACRI0a5dn--P0tuN5hD7H66OdrvXfzGi9VBazXYBm6hUaDirh2SLdcSbsuVDTAz0X6XKjtP8ezsE-NvJy1ofVEs-OAc1QFMohHi0magyR7xUVCplGQ+14gZRNV-sa0cj5ervn0uNd1hrPnPTsvtSRcb3SQCTY8AUzkfjSTkkpNSUhA3Sl2ESgwTSK3uTrb5JtgyhjiV2H5OCA7XJFA8g2wKVl1yCu7fSPtwkq37snceyw152Xmv0Zg2EuGb2bufeO-UU7VGXuas2+9w7d2IdXbO+BotxnrEtYhYx2bcOwdHassj6HPEEdrYldtoI87GPtp4p54rCPloYYg5T4HIAFM8WbNbD7zgGeo5QxT4T2mjUNNFHxrbOanXUGMiJMBEvaAxZmyLgOzrP25ll1L0yuzZfm2J7d0nD3SEbsV1txnFgSfIvcmb8kcri7suNUbgyxrhmW+Dva2nWVbs87idRyye28eI4J1Dp7TxFTNhvYGe3DxHdFOd-oV3bU6ce-6lAjn0cufSE99czNuNZl8VFyjmTEHiNY5ZyRCP1BkPi-vfy8n7zXPDdw3cyElH4Q1+wxLFVXu+Eq7oIwFgbAxGSOkcgBdBSXZu24HsS4MXGKWQaI0bmSwp8h6BsSGGlxSJz+iuniQ1w8VKCEPoXwI5yAKSEMh7NcgajKCn28yilUFGu3dtfoXWZKUWt7W6j1FY74QZm-SGydkg082b61q+gtU4ECWVkmgABb+uAMWReaiuApE-+zUlKFeAiQ0H+76cBbyraSBIA7aHaGBfWFYn4MWeB+gCmRByMqurU7UZ05Bwm+BOmo2DSm8BCj0U2smM27BHE+gnBS2kBvBygqS5WAOXKIh30cGK4ISyGvBKoT0khkQMWbeShrQWe4g44JQ9whAUIx09BsEWC7Kpy9YHa8eAIjARSRhsmxyphViSWKW+hp08QVUvCrBr+I0bQvSDc90WWsm+ijm3heSysdSlhmQEq40nhKh5yYRIgoRnhISkRMYMWpysRdS0UuhPAfq-MQa0a4aFWtMKaca1ooeqAIAAA1MENoBCFkcmlLBoTvk1LZE4R1OZkEdApfmAVBIGNYRBgEcarEYERAj4ZfsHHUN0