(env):\n    input = user_read(input_prompt)\n    if is_none(input):\n        print(\"evaluator terminated\")\n    else:\n        program = parse(input)\n        locals = scan_out_declarations(program)\n        unassigneds = list_of_unassigned(locals)\n        program_env = extend_environment(locals, unassigneds, env)\n        output = evaluate(program, program_env)\n        user_print(output_prompt, output)\n        return driver_loop(program_env) "},{"body":"\n\tWe use Python's ","tag":"#text"},{"tag":"PYTHONINLINE","body":"prompt"},{"body":" function\n\tto request and read the input string from the user:\n\t","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":6,"eval":true,"prependLength":0,"program":"chap=4&prgrm=MQAgygkgwgCgniALAOgIzMQKEwEwKYBmIArgM54BOA+hXgIY4AUADhQPYC2zALladxQCWAOwDmASgBcmELJC1uxCsJCtOPFuy69+QseKA","body":"def user_read(prompt_string):\n    return prompt(prompt_string) "},{"body":"\n    The function\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"prompt"},{"body":" returns\n    ","tag":"#text"},{"tag":"PYTHONINLINE","body":"null"},{"body":" when the user cancels the\n    input. We use a special printing\n    function ","tag":"#text"},{"tag":"PYTHONINLINE","body":"user_print"},{"body":",\n      \n    to avoid printing the environment part of a compound\n    function,\n    which may be a very long list (or may even contain cycles).\n    ","tag":"#text"},{"tag":"SNIPPET","latex":false,"id":7,"eval":true,"prependLength":303,"program":"chap=4&-Fk13VpaFXjUtm9bn--X04zF11ftFj44T+bkLIdPExdF04+Ivw2FlQLfaCVzqDQ86k9dIslo62yQiY1UfsJ84jNcxXcbjA5GmqtJmrOOga6ilmkAw+A8Hsb7stbD5hC6arzB+m7PGeTm6td+xsoH1A2xqhrwmOG5PsH8qYqiLMG6+kdZMatvIRVxICgpcHJ68XE8QOzZtuObSkMwpDq2ePa4Dy3PENwxb2rr-x1wbnsft3ehnvoA-iTh+QvohFMiLLSHLn2B4M7BGGNxPWv+oGX2RBHhwfvuquwu6SeC0L9XymXlsRAB23oU+jv5PdVV9yoSVofEzSRM6B8SkHmH5C-q4Jk6PdME0Ejzxg6BLH+IB7q--o7RExpOuhk481SYwkWHoA2QdTmmdGyjU4p3DInc2idIcWxc6nKn-jfVhJSghlI8aozJVS5nxACbjDZOhcGNBGVdFkUTlAxM5uMk5kzYlhOlokHiOyAQMP3kw9B1zFkmPOac05QcZYWyXLQ